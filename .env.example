# ── TradingView ────────────────────────────────────────────────────────────────
TRADINGVIEW_WEBHOOK_SECRET=change_this_secret

# ── Tradovate Broker ───────────────────────────────────────────────────────────
TRADOVATE_API_BASE_URL=https://demo-api.tradovate.com
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=

# ── Supabase (get these from supabase.com → Project Settings → API) ────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ── Groq AI (get from console.groq.com) ───────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Claude AI (get from console.anthropic.com) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars

# ── Notifications (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Config ─────────────────────────────────────────────────────────────────
PAPER_MODE=true
ORDER_QTY=1
DASHBOARD_PORT=8080

# ── Autonomous Engine ──────────────────────────────────────────────────────────
# Your Clerk user ID (Settings → Profile in the app, or Clerk dashboard)
AUTONOMOUS_USER_ID=user_xxxxxxxxxxxxxxxxxx
# Secret to protect the /api/engine/run endpoint (any random string)
CRON_SECRET=change_this_to_a_random_secret
# Override which pairs the bot trades (comma-separated TradingView symbols)
TRADEABLE_PAIRS=MES1!,MNQ1!,ES1!,NQ1!,SPY,QQQ
